<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Relatório TFD</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f2f2f2; margin: 0; padding: 8px; }
    .barra { background: #fff; padding: 12px; border-radius: 6px; box-shadow: 0 2px 8px rgba(0,0,0,.12); display: flex; gap: 10px; align-items: center; margin-bottom: 15px; }
    .barra input, .barra button { padding: 8px 10px; font-weight: bold; }
    .barra button { border: none; border-radius: 4px; cursor: pointer; background: #4a148c; color: #fff; }
    .barra button:disabled { background: #999; cursor: not-allowed; }

    #telaLogin { position: fixed; inset: 0; background: #f4f7f6; display: flex; align-items: center; justify-content: center; z-index: 9999; }
    .login-card { background: white; padding: 36px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); text-align: center; width: 300px; }
    .login-card input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
    .login-card button { width: 100%; padding: 10px; background: #4a148c; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }

    .page { background: #fff; padding: 8mm; border-radius: 6px; }
    .header { display: flex; align-items: center; gap: 14px; border-bottom: 2px solid #000; padding-bottom: 6px; }
    .header img { height: 65px; }
    .header-text { font-size: 13px; font-weight: bold; line-height: 1.3; text-transform: uppercase; }
    .titulo { text-align: center; font-weight: bold; margin: 8px 0; text-transform: uppercase; }
    .meta { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px; font-weight: bold; }

    .secao { margin-top: 12px; }
    .secao h3 { margin: 0 0 6px; font-size: 13px; text-transform: uppercase; }
    table { width: 100%; border-collapse: collapse; font-size: 10px; table-layout: fixed; }
    th, td { border: 1px solid #000; padding: 4px; text-align: center; vertical-align: middle; word-wrap: break-word; }
    thead th { background: #eaeaea; text-transform: uppercase; }
    .left { text-align: left; }
    .totais { margin-top: 8px; font-weight: bold; font-size: 12px; }

    @media print {
      body { background: #fff; padding: 0; }
      .barra, #telaLogin { display: none !important; }
      .page { border-radius: 0; padding: 2mm; }
      @page { size: A4 landscape; margin: 6mm; }
    }
  </style>
</head>
<body>
<div id="telaLogin">
  <div class="login-card">
    <h3 style="margin-top:0;">Acesso Restrito</h3>
    <input type="text" id="loginUser" placeholder="Usuário">
    <input type="password" id="loginPass" placeholder="Senha">
    <button onclick="fazerLogin()">ENTRAR</button>
    <div id="msgErro" style="color:red; font-size:12px; margin-top:10px; display:none;">Dados incorretos</div>
  </div>
</div>

<div id="conteudo" style="display:none;">
  <div class="barra">
    <label for="dataRel" style="font-weight:bold;">Data:</label>
    <input id="dataRel" type="date">
    <button onclick="gerar()">GERAR</button>
    <button onclick="window.print()" id="btnPrint" disabled>IMPRIMIR</button>
    <span id="statusMsg" class="status-msg"></span>
  </div>

  <div class="page">
    <div class="header">
      <img src="https://lh3.googleusercontent.com/u/0/d/1uRm9gJZ7sShqkZJSu9w7R7LgQ6PgtPnu" alt="Logo">
      <div class="header-text">
        PREFEITURA MUNICIPAL DE CONCEIÇÃO DO TOCANTINS<br>
        SECRETARIA MUNICIPAL DE SAÚDE<br>
        FUNDO MUNICIPAL DE SAÚDE
      </div>
    </div>
    <div class="titulo">RELAÇÃO DOS PACIENTES COM TRATAMENTO FORA DE DOMICÍLIO</div>
    <div class="meta">
      <span>DATA: <span id="dataTexto">-</span></span>
      <span>CIDADE DESTINO: PALMAS / PORTO NACIONAL</span>
    </div>

    <div class="secao">
      <h3>PORTO NACIONAL</h3>
      <table>
        <thead>
          <tr>
            <th style="width:2%;">Nº</th>
            <th style="width:16%;">PACIENTE</th>
            <th style="width:16%;">ACOMPANHANTE</th>
            <th style="width:14%;">TELEFONE</th>
            <th style="width:16%;">MOTIVO</th>
            <th style="width:8%;">HORÁRIO</th>
            <th style="width:15%;">LOCAL</th>
            <th style="width:13%;">CONTROLE</th>
          </tr>
        </thead>
        <tbody id="tbodyPorto"><tr><td colspan="8">Informe a data e clique em GERAR.</td></tr></tbody>
      </table>
      <div class="totais">TOTAL DE PACIENTES (PORTO NACIONAL): <span id="totalPorto">0</span></div>
    </div>

    <div class="secao">
      <h3>PALMAS</h3>
      <table>
        <thead>
          <tr>
            <th style="width:2%;">Nº</th>
            <th style="width:16%;">PACIENTE</th>
            <th style="width:16%;">ACOMPANHANTE</th>
            <th style="width:14%;">TELEFONE</th>
            <th style="width:16%;">MOTIVO</th>
            <th style="width:8%;">HORÁRIO</th>
            <th style="width:15%;">LOCAL</th>
            <th style="width:13%;">CONTROLE</th>
          </tr>
        </thead>
        <tbody id="tbodyPalmas"><tr><td colspan="8">Informe a data e clique em GERAR.</td></tr></tbody>
      </table>
      <div class="totais">TOTAL DE PACIENTES (PALMAS): <span id="totalPalmas">0</span></div>
    </div>

    <div class="totais">TOTAL DE PACIENTES (GERAL): <span id="totalGeral">0</span></div>
  </div>
</div>

<script>
const CREDENCIAIS = { "alsiony": "cko170560", "fernando": "#Caramelo1006", "gleicyane": "cko170560" };
const TEMPO_SESSAO_MINUTOS = 240;

window.onload = function() { verificarLogin(); };

function verificarLogin() {
  const u = localStorage.getItem("sms_user");
  const p = localStorage.getItem("sms_pass");
  const t = localStorage.getItem("sms_time");
  const agora = new Date().getTime();
  const valido = u && p && CREDENCIAIS[u] === p && t && (agora - parseInt(t, 10)) / 1000 / 60 < TEMPO_SESSAO_MINUTOS;
  if (valido) {
    document.getElementById("telaLogin").style.display = "none";
    document.getElementById("conteudo").style.display = "block";
  } else {
    document.getElementById("telaLogin").style.display = "flex";
    document.getElementById("conteudo").style.display = "none";
  }
}

function fazerLogin() {
  const u = document.getElementById("loginUser").value.toLowerCase().trim();
  const p = document.getElementById("loginPass").value.trim();
  if (CREDENCIAIS[u] && CREDENCIAIS[u] === p) {
    localStorage.setItem("sms_user", u);
    localStorage.setItem("sms_pass", p);
    localStorage.setItem("sms_time", new Date().getTime());
    document.getElementById("msgErro").style.display = "none";
    verificarLogin();
  } else {
    document.getElementById("msgErro").style.display = "block";
  }
}

function atualizarStatus(msg, cor) {
  const el = document.getElementById("statusMsg");
  el.textContent = msg || "";
  if (cor) el.style.color = cor;
}

function gerar() {
  const valor = document.getElementById("dataRel").value;
  const btnPrint = document.getElementById("btnPrint");
  btnPrint.disabled = true;
  atualizarStatus("Buscando dados...", "#0b5ed7");

  if (!valor) {
    alert("Selecione a data.");
    atualizarStatus("Selecione uma data para gerar.", "#dc3545");
    return;
  }

  const p = valor.split("-");
  const dataBr = `${p[2]}/${p[1]}/${p[0]}`;
  document.getElementById("dataTexto").innerText = dataBr;

  google.script.run
    .withSuccessHandler(preencher)
    .withFailureHandler(err => {
      const msg = `Erro: ${err.message}`;
      document.getElementById("tbodyPorto").innerHTML = `<tr><td colspan="8" style="color:red;font-weight:bold;">${msg}</td></tr>`;
      document.getElementById("tbodyPalmas").innerHTML = `<tr><td colspan="8" style="color:red;font-weight:bold;">${msg}</td></tr>`;
      atualizarStatus(msg, "#dc3545");
    })
    .buscarDadosRelatorioTFD(dataBr, localStorage.getItem("sms_user"), localStorage.getItem("sms_pass"));
}

function montarTabela(linhas) {
  if (!linhas || linhas.length === 0) return '<tr><td colspan="8">Nenhum registro encontrado.</td></tr>';
  return linhas.map((d, i) => `
    <tr>
      <td>${i + 1}</td>
      <td class="left">${d.paciente || '-'}</td>
      <td class="left">${d.acompanhante || '-'}</td>
      <td>${d.telefone || '-'}</td>
      <td class="left">${d.motivo || '-'}</td>
      <td>${d.horario || '-'}</td>
      <td class="left">${d.local || '-'}</td>
      <td>${d.controle || ''}</td>
    </tr>
  `).join("");
}

window.onload = function() {
  const hoje = new Date();
  const yyyy = hoje.getFullYear();
  const mm = String(hoje.getMonth() + 1).padStart(2, "0");
  const dd = String(hoje.getDate()).padStart(2, "0");
  document.getElementById("dataRel").value = `${yyyy}-${mm}-${dd}`;
  verificarLogin();
};

function preencher(res) {
  const porto = (res && res.portoNacional) || [];
  const palmas = (res && res.palmas) || [];

  document.getElementById("tbodyPorto").innerHTML = montarTabela(porto);
  document.getElementById("tbodyPalmas").innerHTML = montarTabela(palmas);

  document.getElementById("totalPorto").innerText = porto.length;
  document.getElementById("totalPalmas").innerText = palmas.length;
  document.getElementById("totalGeral").innerText = porto.length + palmas.length;

  document.getElementById("btnPrint").disabled = false;
}
</script>
</body>
</html>
